{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "publicPath": "public",
  "routes": [
    { "src": "^/api/?(.*)$", "dest": "/api/index.js" },
    { "src": "^/data/(.*)$", "dest": "/data/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
