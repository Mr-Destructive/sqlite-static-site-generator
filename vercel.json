{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "data/(.*)", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/?(.*)$", "dest": "/api/index.js" },
    { "src": "^/data/(.*)$", "dest": "/data/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
