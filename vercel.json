{
  "version": 2,
  "buildCommand": "mkdir -p public/data && cp -R data/* public/data/ && cp index.html app.js styles.css public/",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "^/api/?(.*)$", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
